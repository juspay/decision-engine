<clickhouse>
  <remote_servers>
    <analytics_cluster>
      <shard>
        <internal_replication>false</internal_replication>
        <replica>
          <host from_env="CLICKHOUSE_SHARD_1_HOST">clickhouse-shard-1</host>
          <port from_env="CLICKHOUSE_TCP_PORT">9000</port>
        </replica>
      </shard>
      <shard>
        <internal_replication>false</internal_replication>
        <replica>
          <host from_env="CLICKHOUSE_SHARD_2_HOST">clickhouse-shard-2</host>
          <port from_env="CLICKHOUSE_TCP_PORT">9000</port>
        </replica>
      </shard>
    </analytics_cluster>
  </remote_servers>
</clickhouse>
